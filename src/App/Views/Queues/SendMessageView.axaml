<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ServiceBusExplorer.ViewModels"
             x:DataType="vm:SendMessageViewModel"
             x:Class="ServiceBusExplorer.App.Views.Queues.SendMessageView">
  <Grid RowDefinitions="Auto,*,Auto">
    <TextBlock Grid.Row="0" Text="Send Message" FontWeight="SemiBold" Margin="0,0,0,8" />

    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="6">
        <TextBlock Text="Body *" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        <TextBox Text="{Binding Body}"
                 AcceptsReturn="True"
                 MinHeight="120"
                 FontFamily="Cascadia Code,Consolas,monospace"
                 TextWrapping="Wrap" />

        <TextBlock Text="Content Type" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        <TextBox Text="{Binding ContentType}" />

        <TextBlock Text="Message ID" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        <TextBox Text="{Binding MessageId}" />

        <TextBlock Text="Correlation ID" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        <TextBox Text="{Binding CorrelationId}" />

        <TextBlock Text="Session ID" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        <TextBox Text="{Binding SessionId}" />

        <TextBlock Text="To" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        <TextBox Text="{Binding To}" />

        <TextBlock Text="Application Properties (JSON)" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        <TextBox Text="{Binding PropertiesJson}"
                 AcceptsReturn="True"
                 MinHeight="60"
                 FontFamily="Cascadia Code,Consolas,monospace"
                 TextWrapping="Wrap" />

        <Separator Margin="0,4" />

        <!-- Batch count + schedule -->
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="Count:" VerticalAlignment="Center" />
          <NumericUpDown Value="{Binding SendCount}" Minimum="1" Maximum="1000" Width="80" />
          <CheckBox Content="Schedule in" IsChecked="{Binding UseScheduledTime}" VerticalAlignment="Center" />
          <NumericUpDown Value="{Binding ScheduleDelayMinutes}" Minimum="1" Maximum="10080" Width="80"
                         IsEnabled="{Binding UseScheduledTime}" />
          <TextBlock Text="min from now" VerticalAlignment="Center"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2" Margin="0,8,0,0" Spacing="6">
      <TextBlock Text="{Binding Error}"
                 IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                 Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                 TextWrapping="Wrap" />
      <Button Content="Send" Command="{Binding SendCommand}" HorizontalAlignment="Stretch" />
    </StackPanel>
  </Grid>
</UserControl>
