<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ServiceBusExplorer.ViewModels"
             xmlns:domain="using:ServiceBusExplorer"
             xmlns:subs="using:ServiceBusExplorer.App.Views.Subscriptions"
             xmlns:ctrl="using:ServiceBusExplorer.App.Views.Controls"
             x:DataType="vm:TopicDetailViewModel"
             x:Class="ServiceBusExplorer.App.Views.Topics.TopicDetailView">
  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Header -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="16,12,16,6">
      <TextBlock Text="{Binding Topic.Name, FallbackValue='Topic'}"
                 FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
      <TextBlock Text="Loading…" IsVisible="{Binding IsLoading}"
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                 VerticalAlignment="Center" />
    </StackPanel>

    <!-- Error -->
    <TextBlock Grid.Row="1" Margin="16,0,16,4"
               Text="{Binding Error}"
               IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
               Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
               TextWrapping="Wrap" />

    <!-- Tabs -->
    <TabControl Grid.Row="2" Margin="4,0,4,4">

      <!-- Description tab -->
      <TabItem Header="Description">
        <ScrollViewer>
          <StackPanel Spacing="14" Margin="16,12">

            <!-- Read-only stats -->
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
              <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                      CornerRadius="4" Padding="10,6" Margin="0,0,8,8">
                <StackPanel>
                  <TextBlock Text="Subscriptions" FontSize="11"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  <TextBlock Text="{Binding Topic.SubscriptionCount, FallbackValue='—'}"
                             FontSize="20" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                      CornerRadius="4" Padding="10,6" Margin="0,0,8,8">
                <StackPanel>
                  <TextBlock Text="Size (bytes)" FontSize="11"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  <TextBlock Text="{Binding Topic.SizeInBytes, FallbackValue='—'}"
                             FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                      CornerRadius="4" Padding="10,6" Margin="0,0,8,8">
                <StackPanel>
                  <TextBlock Text="Status" FontSize="11"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  <TextBlock Text="{Binding Topic.Status, FallbackValue='—'}"
                             FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
            </WrapPanel>

            <Separator />

            <!-- Editable fields -->
            <Grid ColumnDefinitions="180,*"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Message TTL" VerticalAlignment="Center" Margin="0,0,12,8" />
              <ctrl:TimeSpanControl Grid.Row="0" Grid.Column="1" Value="{Binding DefaultMessageTimeToLive}" Margin="0,0,0,8" />

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Auto-delete on Idle" VerticalAlignment="Center" Margin="0,0,12,8" />
              <ctrl:TimeSpanControl Grid.Row="1" Grid.Column="1" Value="{Binding AutoDeleteOnIdle}" Margin="0,0,0,8" />

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Max Size (MB)" VerticalAlignment="Center" Margin="0,0,12,8" />
              <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding MaxSizeInMegabytes}" Minimum="1" Maximum="81920" Width="120" HorizontalAlignment="Left" Margin="0,0,0,8" />

              <TextBlock Grid.Row="3" Grid.Column="0" Text="Batched Operations" VerticalAlignment="Center" Margin="0,0,12,8" />
              <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding EnableBatchedOperations}" Margin="0,0,0,8" />

              <TextBlock Grid.Row="4" Grid.Column="0" Text="User Metadata" VerticalAlignment="Center" Margin="0,0,12,8" />
              <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding UserMetadata}" Margin="0,0,0,8" />

              <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                <Button Content="Update" Command="{Binding UpdateCommand}" />
                <TextBlock Text="Saving…" IsVisible="{Binding IsSaving}" VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                <TextBlock Text="{Binding SaveError}"
                           IsVisible="{Binding SaveError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                           VerticalAlignment="Center" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Subscriptions tab -->
      <TabItem Header="Subscriptions">
        <Grid ColumnDefinitions="260,*">
          <!-- Subscription list -->
          <Grid Grid.Column="0" RowDefinitions="Auto,*" Margin="8,8,4,8">
            <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,6">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Subscriptions" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Content="Refresh" Command="{Binding Subscriptions.RefreshCommand}" />
                <Button Content="+" Command="{Binding Subscriptions.BeginCreateCommand}" />
              </StackPanel>
              <StackPanel IsVisible="{Binding Subscriptions.IsCreating}" Orientation="Horizontal" Spacing="6">
                <TextBox Text="{Binding Subscriptions.NewSubscriptionName}" Watermark="Subscription name" Width="160" />
                <Button Content="Create" Command="{Binding Subscriptions.QuickCreateCommand}" />
                <Button Content="✕" Command="{Binding Subscriptions.CancelCreateCommand}" />
              </StackPanel>
            </StackPanel>
            <ListBox Grid.Row="1" ItemsSource="{Binding Subscriptions.Subscriptions}"
                     SelectedItem="{Binding Subscriptions.SelectedSubscription}">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type domain:SubscriptionInfo}">
                  <StackPanel Spacing="2" Margin="4,2">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ActiveMessageCount, StringFormat='Active: {0}'}" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>

          <!-- Subscription detail -->
          <Border Grid.Column="1" BorderThickness="1,0,0,0"
                  BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <ContentControl Content="{Binding SelectedSubscriptionDetail}" />
          </Border>
        </Grid>
      </TabItem>

      <!-- Send tab -->
      <TabItem Header="Send">
        <ContentControl Content="{Binding Send}" Margin="8" />
      </TabItem>

    </TabControl>
  </Grid>
</UserControl>
