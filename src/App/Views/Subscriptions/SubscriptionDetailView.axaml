<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ServiceBusExplorer.ViewModels"
             xmlns:domain="using:ServiceBusExplorer"
             xmlns:ctrl="using:ServiceBusExplorer.App.Views.Controls"
             x:DataType="vm:SubscriptionDetailViewModel"
             x:Class="ServiceBusExplorer.App.Views.Subscriptions.SubscriptionDetailView">
  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Header -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="16,12,16,6">
      <TextBlock Text="{Binding Info.Name, FallbackValue='Subscription'}"
                 FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
      <TextBlock Text="Loading…" IsVisible="{Binding IsLoading}"
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                 VerticalAlignment="Center" />
    </StackPanel>

    <!-- Error -->
    <TextBlock Grid.Row="1" Margin="16,0,16,4"
               Text="{Binding Error}"
               IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
               Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
               TextWrapping="Wrap" />

    <!-- Tabs -->
    <TabControl Grid.Row="2" Margin="4,0,4,4">

      <!-- Description tab -->
      <TabItem Header="Description">
        <ScrollViewer>
          <StackPanel Spacing="14" Margin="16,12">

            <!-- Read-only stats -->
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
              <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                      CornerRadius="4" Padding="10,6" Margin="0,0,8,8">
                <StackPanel>
                  <TextBlock Text="Active Messages" FontSize="11"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  <TextBlock Text="{Binding Info.ActiveMessageCount, FallbackValue='—'}"
                             FontSize="20" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                      CornerRadius="4" Padding="10,6" Margin="0,0,8,8">
                <StackPanel>
                  <TextBlock Text="Dead-letter" FontSize="11"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  <TextBlock Text="{Binding Info.DeadLetterCount, FallbackValue='—'}"
                             FontSize="20" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                      CornerRadius="4" Padding="10,6" Margin="0,0,8,8">
                <StackPanel>
                  <TextBlock Text="Status" FontSize="11"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                  <TextBlock Text="{Binding Info.Status, FallbackValue='—'}"
                             FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
            </WrapPanel>

            <Separator />

            <!-- Editable fields -->
            <Grid ColumnDefinitions="180,*"
                  RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Lock Duration" VerticalAlignment="Center" Margin="0,0,12,8" />
              <ctrl:TimeSpanControl Grid.Row="0" Grid.Column="1" Value="{Binding LockDuration}" Margin="0,0,0,8" />

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Max Delivery Count" VerticalAlignment="Center" Margin="0,0,12,8" />
              <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding MaxDeliveryCount}" Minimum="1" Maximum="2000" Width="120" HorizontalAlignment="Left" Margin="0,0,0,8" />

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Message TTL" VerticalAlignment="Center" Margin="0,0,12,8" />
              <ctrl:TimeSpanControl Grid.Row="2" Grid.Column="1" Value="{Binding DefaultMessageTimeToLive}" Margin="0,0,0,8" />

              <TextBlock Grid.Row="3" Grid.Column="0" Text="Auto-delete on Idle" VerticalAlignment="Center" Margin="0,0,12,8" />
              <ctrl:TimeSpanControl Grid.Row="3" Grid.Column="1" Value="{Binding AutoDeleteOnIdle}" Margin="0,0,0,8" />

              <TextBlock Grid.Row="4" Grid.Column="0" Text="Batched Operations" VerticalAlignment="Center" Margin="0,0,12,8" />
              <CheckBox Grid.Row="4" Grid.Column="1" IsChecked="{Binding EnableBatchedOperations}" Margin="0,0,0,8" />

              <TextBlock Grid.Row="5" Grid.Column="0" Text="Dead-letter on Expiry" VerticalAlignment="Center" Margin="0,0,12,8" />
              <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding EnableDeadLetteringOnMessageExpiration}" Margin="0,0,0,8" />

              <TextBlock Grid.Row="6" Grid.Column="0" Text="Forward To" VerticalAlignment="Center" Margin="0,0,12,8" />
              <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding ForwardTo}" Margin="0,0,0,8" />

              <TextBlock Grid.Row="7" Grid.Column="0" Text="Forward DL To" VerticalAlignment="Center" Margin="0,0,12,8" />
              <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding ForwardDeadLetteredMessagesTo}" Margin="0,0,0,8" />

              <TextBlock Grid.Row="8" Grid.Column="0" Text="User Metadata" VerticalAlignment="Center" Margin="0,0,12,8" />
              <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding UserMetadata}" Margin="0,0,0,8" />

              <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                <Button Content="Update" Command="{Binding UpdateCommand}" />
                <TextBlock Text="Saving…" IsVisible="{Binding IsSaving}" VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                <TextBlock Text="{Binding SaveError}"
                           IsVisible="{Binding SaveError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                           VerticalAlignment="Center" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>

          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- Messages tab -->
      <TabItem Header="Messages">
        <Grid RowDefinitions="Auto,*,Auto">
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="8,8,8,4">
            <NumericUpDown Value="{Binding PeekCount}" Minimum="1" Maximum="1000" Width="80" />
            <Button Content="Peek" Command="{Binding PeekCommand}" />
            <Button Content="Purge" Command="{Binding PurgeCommand}" />
          </StackPanel>
          <ListBox Grid.Row="1" ItemsSource="{Binding Messages}" SelectedItem="{Binding SelectedMessage}" Margin="8,0">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="{x:Type domain:ReceivedMessage}">
                <StackPanel Spacing="2" Margin="4,2">
                  <TextBlock Text="{Binding MessageId}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding EnqueuedTime, StringFormat='Enqueued: {0:g}'}" FontSize="11"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <Border Grid.Row="2" BorderThickness="0,1,0,0" MaxHeight="180"
                  BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                  IsVisible="{Binding SelectedMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
                  Padding="8">
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding SelectedMessage.MessageId, StringFormat='ID: {0}'}" Margin="0,2" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding SelectedMessage.SequenceNumber, StringFormat='Seq: {0}'}" Margin="0,2" />
              <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding SelectedMessage.DeliveryCount, StringFormat='Delivery: {0}'}" Margin="0,2" />
              <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding SelectedMessage.DeadLetterReason, StringFormat='DL Reason: {0}'}"
                         IsVisible="{Binding SelectedMessage.DeadLetterReason, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Margin="0,2" />
              <TextBox Grid.Row="0" Grid.Column="1" Grid.RowSpan="4"
                       Text="{Binding SelectedMessage.Body}"
                       IsReadOnly="True" AcceptsReturn="True"
                       FontFamily="Courier New,monospace"
                       TextWrapping="Wrap" />
            </Grid>
          </Border>
        </Grid>
      </TabItem>

      <!-- Dead-letter tab -->
      <TabItem Header="Dead-letter">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="8,8,8,4">
            <NumericUpDown Value="{Binding PeekCount}" Minimum="1" Maximum="1000" Width="80" />
            <Button Content="Peek DL" Command="{Binding PeekCommand}" />
            <Button Content="Purge DL" Command="{Binding PurgeCommand}" />
          </StackPanel>
          <ListBox Grid.Row="1" ItemsSource="{Binding Messages}" SelectedItem="{Binding SelectedMessage}" Margin="8,0">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="{x:Type domain:ReceivedMessage}">
                <StackPanel Spacing="2" Margin="4,2">
                  <TextBlock Text="{Binding MessageId}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding DeadLetterReason}" FontSize="11"
                             Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </TabItem>

      <!-- Filters tab -->
      <TabItem Header="Filters">
        <ContentControl Content="{Binding Rules}" Margin="4" />
      </TabItem>

      <!-- Send tab -->
      <TabItem Header="Send">
        <ContentControl Content="{Binding Send}" Margin="8" />
      </TabItem>

    </TabControl>
  </Grid>
</UserControl>
