<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ServiceBusExplorer.App.Views.Dialogs.AboutDialog"
        Title="About Service Bus Explorer"
        Width="420" Height="280"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <StackPanel Spacing="12" Margin="28">
    <TextBlock Text="Service Bus Explorer" FontSize="22" FontWeight="SemiBold" />
    <TextBlock x:Name="VersionText"
               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
    <TextBlock Text="Cross-platform Avalonia rewrite of the original WinForms Service Bus Explorer."
               TextWrapping="Wrap" />
    <TextBlock Text="© 2024-2026 Contributors" FontSize="11"
               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />

    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
      <Button Content="GitHub" Click="OnGitHub" />
      <Button Content="Close" Click="OnClose" />
    </StackPanel>
  </StackPanel>
</Window>
