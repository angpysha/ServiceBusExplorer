<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ServiceBusExplorer.ViewModels"
             xmlns:domain="using:ServiceBusExplorer"
             x:DataType="vm:NotificationHubListViewModel"
             x:Class="ServiceBusExplorer.App.Views.NotificationHubs.NotificationHubListView">
  <Grid ColumnDefinitions="280,*">

    <!-- List -->
    <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*" Margin="16,12,8,12">
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
        <TextBlock Text="Notification Hubs" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
        <Button Content="Refresh" Command="{Binding RefreshCommand}" VerticalAlignment="Center" />
        <TextBlock Text="Loading…" IsVisible="{Binding IsLoading}"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      </StackPanel>

      <TextBlock Grid.Row="1"
                 Text="{Binding Error}"
                 IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                 Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                 Margin="0,0,0,8" TextWrapping="Wrap" />

      <ListBox Grid.Row="2"
               ItemsSource="{Binding NotificationHubs}"
               SelectedItem="{Binding SelectedHub}"
               Background="Transparent"
               BorderThickness="0">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="{x:Type domain:NotificationHubInfo}">
            <StackPanel Spacing="2" Margin="4,2">
              <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding RegistrationCount, StringFormat='Registrations: {0}'}" FontSize="12"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>

    <!-- Detail -->
    <Border Grid.Column="1"
            BorderThickness="1,0,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
      <ContentControl Content="{Binding SelectedDetail}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch" />
    </Border>
  </Grid>
</UserControl>
